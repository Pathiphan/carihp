# ================================================
# CARIHP.ID v2 — Environment Variables
# ================================================
# Salin file ini → rename jadi .env.local → isi semua nilainya
# Jangan pernah upload .env.local ke GitHub!

# --- SUPABASE ---
# Dari: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- RAPIDAPI (untuk fetch spesifikasi HP) ---
# Dari: https://rapidapi.com → cari "GSMArena" → subscribe → copy API key
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GROQ AI (untuk rekomendasi & verdict) ---
# Dari: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- RESEND (untuk email notifikasi watchlist) ---
# Dari: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# --- ADMIN ---
# Buat password sendiri, minimal 8 karakter
ADMIN_PASSWORD=passwordrahasiakamu123

# --- CRON (keamanan cron job, buat string acak) ---
# Contoh: buka terminal → ketik: openssl rand -hex 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
